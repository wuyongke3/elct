{
  "$schema": "./node_modules/app-builder-lib/scheme.json",
  "appId": "com.easygo.gif-toolbox",
  "asar": true,
  "productName": "GIF 工具箱",
  "copyright": "Copyright © 2026 easygo",
  "directories": {
    "output": "dist/${os}"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  "mac": {
    "target": ["dmg"],
    "artifactName": "${productName}-v${version}-macOS.${ext}",
    "category": "public.app-category.utilities"
  },
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "artifactName": "${productName}-v${version}-win64.${ext}"
  },
  "linux": {
    "target": ["AppImage"],
    "artifactName": "${productName}-v${version}-linux.${ext}",
    "category": "Utility"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  }
}
